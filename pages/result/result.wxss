.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Hidden canvas for share image generation */
.share-canvas {
  position: fixed;
  left: -9999rpx;
  top: 0;
}

.result-card {
  width: 600rpx;
  background: linear-gradient(180deg, #fff 0%, #f9f9f9 100%);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin-top: 60rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.brand-label {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.milk-tea-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-top: 20rpx;
}

.description {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-top: 20rpx;
}

.user-section {
  display: flex;
  align-items: center;
  margin-top: 60rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 30rpx;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.nickname {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.login-prompt {
  margin-top: 40rpx;
  text-align: center;
  padding: 30rpx;
  background: #fff8e6;
  border-radius: 12rpx;
}

.prompt-text {
  font-size: 26rpx;
  color: #996600;
}

.login-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 30rpx;
  border: none;
}

.actions {
  display: flex;
  gap: 30rpx;
  margin-top: 60rpx;
}

.action-btn {
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  border-radius: 30rpx;
}

.retry-btn {
  background: #fff;
  color: #333;
  border: 2rpx solid #ddd;
}

.share-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
  border: none;
}

/* ====== Result Animation Styles ====== */

/* Animation container - centered above result card */
.result-animation-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 60rpx auto 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* Capsule - transparent sphere for result reveal */
.result-capsule {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.3) 50%, rgba(255,255,255,0.1) 100%);
  border: 2rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 0 20rpx rgba(255,255,255,0.3), inset 0 0 20rpx rgba(255,255,255,0.2);
  position: absolute;
  opacity: 0;
  transform: scale(0);
}

/* Pearl inside capsule */
.result-pearl {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #F5A6A0;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0);
  opacity: 0;
}

/* Result name inside capsule */
.result-capsule-name {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0);
  font-size: 20rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  white-space: nowrap;
  opacity: 0;
}

/* Pearl graphic below card */
.pearl-graphic {
  margin-top: 30rpx;
  display: flex;
  justify-content: center;
  opacity: 0;
}

.pearl-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.9) 0%, #F5A6A0 50%, rgba(245,166,160,0.8) 100%);
  box-shadow: 0 4rpx 12rpx rgba(245,166,160,0.4);
}

/* Animation keyframes */

/* Capsule pop in */
@keyframes capsule-popin {
  0% {
    opacity: 0;
    transform: scale(0);
  }
  60% {
    opacity: 1;
    transform: scale(1.1);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* Capsule open - splits in middle */
@keyframes capsule-open-result {
  0% {
    transform: scale(1);
    border-radius: 50%;
  }
  40% {
    transform: scale(1.3);
    border-radius: 50%;
  }
  60% {
    transform: scale(1.3);
    border-radius: 30% 30% 50% 50%;
  }
  100% {
    transform: scale(0);
    border-radius: 50%;
    opacity: 0;
  }
}

/* Pearl bounce in */
@keyframes pearl-bounce {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0);
  }
  60% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.3);
  }
  80% {
    transform: translate(-50%, -50%) scale(0.9);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

/* Result name fade in */
@keyframes result-name-fadein {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

/* Result card reveal with bounce */
@keyframes card-reveal {
  0% {
    opacity: 0;
    transform: translateY(30rpx);
  }
  60% {
    opacity: 1;
    transform: translateY(-10rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Pearl glow pulse */
@keyframes pearl-glow {
  0%, 100% {
    box-shadow: 0 0 10rpx rgba(245,166,160,0.5);
  }
  50% {
    box-shadow: 0 0 20rpx rgba(245,166,160,0.8);
  }
}

.pearl-glow {
  animation: pearl-glow 1.5s ease-in-out infinite;
}