.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-card {
  width: 600rpx;
  background: linear-gradient(180deg, #fff 0%, #f9f9f9 100%);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin-top: 60rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.brand-label {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.milk-tea-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-top: 20rpx;
}

.description {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-top: 20rpx;
}

.user-section {
  display: flex;
  align-items: center;
  margin-top: 60rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 30rpx;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.nickname {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.login-prompt {
  margin-top: 40rpx;
  text-align: center;
  padding: 30rpx;
  background: #fff8e6;
  border-radius: 12rpx;
}

.prompt-text {
  font-size: 26rpx;
  color: #996600;
}

.login-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 30rpx;
  border: none;
}

.actions {
  display: flex;
  gap: 30rpx;
  margin-top: 60rpx;
}

.action-btn {
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  border-radius: 30rpx;
}

.retry-btn {
  background: #fff;
  color: #333;
  border: 2rpx solid #ddd;
}

.share-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
  border: none;
}