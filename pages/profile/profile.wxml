<view class="container">
  <block wx:if="{{userInfo}}">
    <view class="profile-header">
      <image class="avatar" src="{{userInfo.avatarUrl}}"></image>
      <text class="nickname">{{userInfo.nickName}}</text>
    </view>
    <view class="stats">
      <view class="stat-item">
        <text class="stat-value">{{drawCount}}</text>
        <text class="stat-label">抽取次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{points}}</text>
        <text class="stat-label">积分</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{achievementCount}}</text>
        <text class="stat-label">成就</text>
      </view>
    </view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onHistoryTap">
        <text>抽取历史</text>
        <text class="arrow">></text>
      </view>
      <view class="menu-item" bindtap="onAchievementTap">
        <text>我的成就</text>
        <text class="arrow">></text>
      </view>
      <view class="menu-item logout" bindtap="onLogoutTap">
        <text>退出登录</text>
      </view>
    </view>
  </block>
  <block wx:else>
    <view class="not-logged">
      <image class="guest-avatar" src="/assets/default-avatar.png"></image>
      <text class="guest-text">未登录</text>
      <button class="login-btn" bindtap="onLoginTap">点击登录</button>
    </view>
  </block>
</view>