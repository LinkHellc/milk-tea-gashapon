<view class="container" style="background: linear-gradient(180deg, #f8f8f8 0%, #fff5f5 100%);">

  <!-- User info -->
  <view class="user-card">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"></image>
    <text class="nickname">{{userInfo.nickName || '微信用户'}}</text>
  </view>

  <!-- Points display -->
  <view class="points-card">
    <view class="points-main">
      <text class="points-number">{{totalPoints}}</text>
      <text class="points-label">积分</text>
    </view>
    <view class="points-stats">
      <view class="stat-item">
        <text class="stat-value">{{totalDraws}}</text>
        <text class="stat-label">抽取次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{unlockedCount}}</text>
        <text class="stat-label">已解锁成就</text>
      </view>
    </view>
  </view>

  <!-- Achievements -->
  <view class="section">
    <text class="section-title">我的成就</text>
    <view class="achievements-grid">
      <view wx:for="{{achievements}}" wx:key="id"
            class="achievement-item {{item.unlocked ? 'unlocked' : 'locked'}}">
        <text class="achievement-icon">{{item.unlocked ? item.icon : '🔒'}}</text>
        <text class="achievement-name">{{item.unlocked ? item.name : '???'}}</text>
      </view>
    </view>
  </view>

  <!-- Actions -->
  <view class="actions">
    <button class="action-btn" bindtap="goHistory">查看抽取历史</button>
    <button class="action-btn secondary" bindtap="goDraw">再去抽取</button>
  </view>

</view>
