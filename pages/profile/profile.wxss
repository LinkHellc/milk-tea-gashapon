.container {
  min-height: 100vh;
  padding: 30rpx;
}

.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.nickname {
  margin-top: 20rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.points-card {
  background: linear-gradient(135deg, #ffb7b2 0%, #ffc3a0 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 30rpx;
}

.points-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 30rpx;
}

.points-number {
  font-size: 72rpx;
  font-weight: bold;
}

.points-label {
  font-size: 28rpx;
  margin-left: 10rpx;
}

.points-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.3);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.achievements-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
  background: #f9f9f9;
}

.achievement-item.unlocked {
  background: linear-gradient(180deg, #fff5f5 0%, #ffe8e8 100%);
}

.achievement-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.achievement-item.locked .achievement-icon {
  filter: grayscale(1);
  opacity: 0.4;
}

.achievement-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.achievement-item.locked .achievement-name {
  color: #ccc;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-btn {
  background: #ffb7b2;
  color: #fff;
  font-size: 28rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  border: none;
}

.action-btn.secondary {
  background: #fff;
  color: #333;
  border: 2rpx solid #ddd;
}
