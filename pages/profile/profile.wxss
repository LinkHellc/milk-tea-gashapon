.container {
  padding: 30rpx;
  min-height: 100vh;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.nickname {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  margin-top: 20rpx;
}

.stats {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 0;
  margin-bottom: 40rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B6B;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #333;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.logout {
  color: #FF6B6B;
  justify-content: center;
}

.not-logged {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.guest-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  opacity: 0.5;
}

.guest-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 20rpx;
}

.login-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 80rpx;
  border-radius: 30rpx;
  border: none;
}