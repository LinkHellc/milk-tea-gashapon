.container {
  min-height: 100vh;
  padding: 30rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

.go-btn {
  margin-top: 40rpx;
  background: #ffb7b2;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 30rpx;
  border: none;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.history-pearl {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.9) 0%, #F5A6A0 50%, rgba(245,166,160,0.8) 100%);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.history-info {
  flex: 1;
}

.history-brand {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.history-milktea {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-top: 4rpx;
}

.history-time {
  font-size: 22rpx;
  color: #ccc;
  flex-shrink: 0;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}
