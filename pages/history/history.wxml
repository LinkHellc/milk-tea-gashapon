<view class="container" style="background: linear-gradient(180deg, #f8f8f8 0%, #fff5f5 100%);">

  <!-- Empty state -->
  <view wx:if="{{!history || history.length === 0}}" class="empty-state">
    <text class="empty-icon">📜</text>
    <text class="empty-text">暂无抽取记录</text>
    <text class="empty-hint">去抽一杯奶茶吧</text>
    <button class="go-btn" bindtap="goDraw">去抽取</button>
  </view>

  <!-- History list -->
  <view wx:else class="history-list">
    <view class="history-item" wx:for="{{history}}" wx:key="index">
      <view class="history-pearl"></view>
      <view class="history-info">
        <text class="history-brand">{{item.brandName}}</text>
        <text class="history-milktea">{{item.milkTeaName}}</text>
      </view>
      <text class="history-time">{{item.timeStr}}</text>
    </view>
  </view>

  <!-- Load more -->
  <view wx:if="{{hasMore && history.length > 0}}" class="load-more" bindtap="loadMore">
    <text>{{loading ? '加载中...' : '加载更多'}}</text>
  </view>

</view>
