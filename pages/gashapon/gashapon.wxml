<view class="container" style="background: linear-gradient(180deg, #f8f8f8 0%, #fff5f5 100%);">

  <!-- Brand Dropdown Selector (D-11) -->
  <view class="brand-selector" bindtap="toggleDropdown">
    <text class="current-brand">{{currentBrand.name}}</text>
    <text class="arrow {{showDropdown ? 'arrow-up' : ''}}">▼</text>
  </view>

  <!-- Dropdown Panel -->
  <view wx:if="{{showDropdown}}" class="dropdown-panel">
    <view wx:for="{{brands}}" wx:key="id"
          class="dropdown-item {{item.id === currentBrand.id ? 'selected' : ''}}"
          bindtap="onBrandChange"
          data-brand-index="{{index}}">
      <text>{{item.name}}</text>
    </view>
  </view>

  <!-- Milk Tea Cup Machine with Animation -->
  <view class="machine-container" style="position: relative;">
    <!-- Cup tilt wrapper - animates when spinning -->
    <view class="{{isSpinning ? 'cup-tilt' : ''}}" style="transition: transform 0.2s ease-in;">
      <view class="machine-card" style="background: linear-gradient(180deg, {{currentBrand.color}} 0%, {{currentBrand.color}}dd 100%);">
        <!-- Cup Lid -->
        <view class="machine-cup-lid" style="background: linear-gradient(180deg, {{currentBrand.color}}bb 0%, {{currentBrand.color}}88 100%);"></view>
        <!-- Cup Body -->
        <view class="machine-cup-body">
          <!-- Large Logo Placeholder -->
          <view class="machine-logo-placeholder" style="background: rgba(255,255,255,0.9);">
            <text class="machine-initials" style="color: {{currentBrand.color}};">{{currentBrand.name.[0]}}</text>
          </view>
          <!-- Brand Name -->
          <text class="machine-brand-name">{{currentBrand.name}}</text>
          <!-- Hint Text -->
          <text class="machine-hint">点击下方按钮抽取</text>
        </view>
        <!-- Straw Hole (with straw visual) -->
        <view class="machine-straw-hole"></view>
        <view class="straw-visual" style="position: absolute; right: 40rpx; top: 60rpx; width: 16rpx; height: 80rpx; background: linear-gradient(180deg, {{currentBrand.color}}cc 0%, {{currentBrand.color}}88 100%); border-radius: 8rpx;"></view>
      </view>
    </view>

    <!-- Capsule Animation Layer - positioned above cup -->
    <view class="animation-layer" wx:if="{{isSpinning}}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; justify-content: center; align-items: flex-start; pointer-events: none;">
      <!-- Capsule -->
      <view class="capsule {{capsuleClass}}" style="position: relative;">
        <!-- Pearl inside -->
        <view class="capsule-pearl {{showPearl ? 'pearl-visible' : ''}}"></view>
        <!-- Result reveal -->
        <view class="capsule-result {{showResult ? 'result-visible' : ''}}">
          <text class="result-name">{{resultMilkTea.name}}</text>
          <view class="result-pearl"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- Action Area with CTA -->
  <view class="action-area">
    <button class="gashapon-btn {{isSpinning ? 'loading pulsing' : ''}}" bindtap="onGashaponTap" hover-class="btn-hover" disabled="{{isSpinning}}">
      {{isSpinning ? '抽取中...' : '扭一下'}}
    </button>
  </view>

  <!-- Custom milk tea section -->
  <view class="custom-section" bindtap="toggleCustomPanel">
    <text class="custom-icon">➕</text>
    <text class="custom-label">添加自定义奶茶</text>
  </view>

  <!-- Custom milk tea panel -->
  <view wx:if="{{showCustomPanel}}" class="custom-panel">
    <view class="custom-panel-header">
      <text class="custom-panel-title">添加自定义奶茶</text>
      <text class="custom-panel-close" bindtap="toggleCustomPanel">✕</text>
    </view>

    <view class="custom-form">
      <input class="custom-input"
             placeholder="输入奶茶名称"
             value="{{customName}}"
             bindinput="onCustomNameInput"
             maxlength="20"/>
      <input class="custom-input"
             placeholder="一句话介绍（可选）"
             value="{{customDesc}}"
             bindinput="onCustomDescInput"
             maxlength="50"/>
      <button class="custom-submit-btn" bindtap="submitCustomMilkTea">添加</button>
    </view>

    <!-- Custom milk teas list -->
    <view wx:if="{{customMilkTeas.length > 0}}" class="custom-list">
      <text class="custom-list-title">我的定制 ({{customMilkTeas.length}})</text>
      <view wx:for="{{customMilkTeas}}" wx:key="id" class="custom-item">
        <text class="custom-item-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- User Info (from Phase 1 auth) -->
  <view class="user-info" wx:if="{{userInfo}}">
    <image class="avatar" src="{{userInfo.avatarUrl}}"></image>
    <text class="nickname">{{userInfo.nickName}}</text>
  </view>

</view>
