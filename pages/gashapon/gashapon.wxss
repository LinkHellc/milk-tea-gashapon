.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.machine {
  width: 400rpx;
  height: 500rpx;
  margin: 60rpx 0;
}

.machine-body {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #8B4513 0%, #D2691E 50%, #8B4513 100%);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.brand-name {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.machine-hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 20rpx;
}

.action-area {
  margin-top: 60rpx;
}

.gashapon-btn {
  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
}

.btn-hover {
  opacity: 0.8;
}

.user-info {
  display: flex;
  align-items: center;
  margin-top: 40rpx;
  padding: 20rpx;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.nickname {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #666;
}