/* Container with gradient background (D-12) */
.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Brand Selector / Dropdown Trigger (D-11) */
.brand-selector {
  width: 100%;
  height: 72rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  margin-bottom: 0;
}

.current-brand {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.arrow {
  font-size: 24rpx;
  color: #999999;
  transition: transform 0.2s;
}

.arrow-up {
  transform: rotate(180deg);
}

/* Dropdown Panel */
.dropdown-panel {
  width: 100%;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  max-height: 400rpx;
  overflow-y: scroll;
  z-index: 100;
}

.dropdown-item {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333333;
}

.dropdown-item.selected {
  background: #fff5f5;
  color: #ffb7b2;
}

/* Machine Container */
.machine-container {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

/* Milk Tea Cup Machine Card (400rpx x 500rpx per UI-SPEC) */
.machine-card {
  width: 400rpx;
  height: 500rpx;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.15);
}

/* Machine Cup Lid */
.machine-cup-lid {
  height: 60rpx;
  width: 100%;
  border-radius: 24rpx 24rpx 0 0;
}

/* Machine Cup Body */
.machine-cup-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
}

/* Large Logo Placeholder */
.machine-logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.machine-initials {
  font-size: 72rpx;
  font-weight: 600;
}

/* Machine Brand Name */
.machine-brand-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #333333;
  text-shadow: 0 2rpx 4rpx rgba(255,255,255,0.8);
  margin-bottom: 16rpx;
}

/* Machine Hint */
.machine-hint {
  font-size: 24rpx;
  color: rgba(51,51,51,0.6);
  margin-top: 8rpx;
}

/* Machine Straw Hole */
.machine-straw-hole {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  position: absolute;
  top: 72rpx;
  right: 48rpx;
}

/* Action Area */
.action-area {
  margin-top: 40rpx;
}

/* Gashapon Button (per UI-SPEC: 400rpx x 96rpx pill) */
.gashapon-btn {
  width: 400rpx;
  height: 96rpx;
  background: #ffb7b2;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255,183,178,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-hover {
  opacity: 0.85;
  box-shadow: 0 4rpx 12rpx rgba(255,183,178,0.3);
}

/* User Info (preserved from Phase 1) */
.user-info {
  display: flex;
  align-items: center;
  margin-top: 40rpx;
  padding: 20rpx;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.nickname {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #666666;
}
