/* Container with gradient background (D-12) */
.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Brand Selector / Dropdown Trigger (D-11) */
.brand-selector {
  width: 100%;
  height: 72rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  margin-bottom: 0;
}

.current-brand {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.arrow {
  font-size: 24rpx;
  color: #999999;
  transition: transform 0.2s;
}

.arrow-up {
  transform: rotate(180deg);
}

/* Dropdown Panel */
.dropdown-panel {
  width: 100%;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  max-height: 400rpx;
  overflow-y: scroll;
  z-index: 100;
}

.dropdown-item {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333333;
}

.dropdown-item.selected {
  background: #fff5f5;
  color: #ffb7b2;
}

/* Machine Container */
.machine-container {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

/* Milk Tea Cup Machine Card (400rpx x 500rpx per UI-SPEC) */
.machine-card {
  width: 400rpx;
  height: 500rpx;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.15);
}

/* Machine Cup Lid */
.machine-cup-lid {
  height: 60rpx;
  width: 100%;
  border-radius: 24rpx 24rpx 0 0;
}

/* Machine Cup Body */
.machine-cup-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
}

/* Large Logo Placeholder */
.machine-logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.machine-initials {
  font-size: 72rpx;
  font-weight: 600;
}

/* Machine Brand Name */
.machine-brand-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #333333;
  text-shadow: 0 2rpx 4rpx rgba(255,255,255,0.8);
  margin-bottom: 16rpx;
}

/* Machine Hint */
.machine-hint {
  font-size: 24rpx;
  color: rgba(51,51,51,0.6);
  margin-top: 8rpx;
}

/* Machine Straw Hole */
.machine-straw-hole {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  position: absolute;
  top: 72rpx;
  right: 48rpx;
}

/* Action Area */
.action-area {
  margin-top: 40rpx;
}

/* Gashapon Button (per UI-SPEC: 400rpx x 96rpx pill) */
.gashapon-btn {
  width: 400rpx;
  height: 96rpx;
  background: #ffb7b2;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255,183,178,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-hover {
  opacity: 0.85;
  box-shadow: 0 4rpx 12rpx rgba(255,183,178,0.3);
}

/* User Info (preserved from Phase 1) */
.user-info {
  display: flex;
  align-items: center;
  margin-top: 40rpx;
  padding: 20rpx;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.nickname {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #666666;
}

/* ====== Animation Styles ====== */

/* Cup tilt animation - simulates drinking posture */
.cup-tilt {
  transform: rotate(15deg);
  transition: transform 0.2s ease-in;
}

/* Animation container - positioned above cup */
.animation-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  display: flex;
  justify-content: center;
  align-items: flex-start;
}

/* Capsule - transparent sphere */
.capsule {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.3) 50%, rgba(255,255,255,0.1) 100%);
  border: 2rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 0 20rpx rgba(255,255,255,0.3), inset 0 0 20rpx rgba(255,255,255,0.2);
  position: absolute;
  top: 80rpx;
  opacity: 0;
  transform: translateY(0) rotate(0deg) scale(0);
}

/* Pearl inside capsule */
.capsule-pearl {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #F5A6A0;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  opacity: 0;
}

/* Result reveal inside capsule */
.capsule-result {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  opacity: 0;
}

.capsule-result .result-name {
  font-size: 20rpx;
  font-weight: 600;
  color: #333333;
  white-space: nowrap;
}

.capsule-result .result-pearl {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #F5A6A0;
  margin: 4rpx auto 0;
}

/* Animation keyframes */

/* Capsule spiral rise through straw */
@keyframes capsule-rise {
  0% {
    opacity: 0;
    transform: translateY(300rpx) rotate(0deg) scale(0.3);
  }
  15% {
    opacity: 1;
    transform: translateY(240rpx) rotate(180deg) scale(0.5);
  }
  50% {
    opacity: 1;
    transform: translateY(120rpx) rotate(540deg) scale(0.8);
  }
  80% {
    opacity: 1;
    transform: translateY(40rpx) rotate(720deg) scale(1);
  }
  100% {
    opacity: 1;
    transform: translateY(0) rotate(900deg) scale(1);
  }
}

/* Capsule eject - pop out above cup */
@keyframes capsule-eject {
  0% {
    opacity: 1;
    transform: translateY(0) rotate(900deg) scale(1);
  }
  100% {
    opacity: 1;
    transform: translateY(-80rpx) rotate(1080deg) scale(1.1);
  }
}

/* Capsule open - splits open */
@keyframes capsule-open {
  0% {
    transform: scale(1.1);
    border-radius: 50%;
  }
  40% {
    transform: scale(1.3);
    border-radius: 50%;
  }
  60% {
    transform: scale(1.3);
    border-radius: 30% 30% 50% 50%;
  }
  100% {
    transform: scale(0);
    border-radius: 50%;
  }
}

/* Pearl fade in */
@keyframes pearl-fadein {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0);
  }
  60% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.2);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

/* Result name fade in */
@keyframes result-fadein {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

/* Button loading state */
.gashapon-btn.loading {
  background: #cccccc;
  box-shadow: none;
}

.gashapon-btn.loading::after {
  content: '抽取中...';
}

/* Pulsing animation for loading state */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.gashapon-btn.pulsing {
  animation: pulse 1s ease-in-out infinite;
}
